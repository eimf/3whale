# Web app (Next.js) – copy to .env.local and fill in. Do not commit .env.local.

# Auth (required) – long random string, e.g. openssl rand -hex 32
AUTH_JWT_SECRET=

# Postgres (required for login) – same DB as backend
DATABASE_URL=

# Backend API (required for dashboard data)
INTERNAL_API_BASE_URL=
INTERNAL_API_KEY=
