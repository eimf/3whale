# Backend (API + Worker) – copy to .env and fill in. Do not commit .env.

# Database (required)
DATABASE_URL=

# Redis (required for worker)
REDIS_URL=

# Internal API secret – BFF and scripts send this in x-internal-api-key (required)
INTERNAL_API_KEY=

# Base URL of this API – set in apps/web for BFF (e.g. https://api.yourdomain.com)
INTERNAL_API_BASE_URL=

# Server
PORT=3000
APP_URL=

# Shopify (required)
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOP_TIMEZONE_IANA=
SHOP_CURRENCY_CODE=

# Optional
SHOPIFY_API_VERSION=2025-04
SHOPIFY_SYNC_PAGE_SIZE=100
SHOPIFY_SYNC_OVERLAP_DAYS=2
SHOPIFY_INITIAL_BACKFILL_DAYS=30
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=

# Admin bootstrap (one-time): set only when running pnpm run bootstrap:admin
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
